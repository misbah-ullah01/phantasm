# .env.example
# Copy this file to .env and fill in your actual values
# This file is safe to commit to GitHub

# Docker Hub Configuration
# Replace with your actual Docker Hub username
DOCKERHUB_USER=your-dockerhub-username-here

# AWS EC2 Configuration (used by CI/CD pipeline)
# Only needed if you are using the automated deployment
EC2_HOST=your-ec2-elastic-ip-here
EC2_USER=ubuntu

# Note: Do NOT add sensitive values here (SSH keys, passwords, etc.)
# Add them only in your local .env file or GitHub Secrets